# ncd aws apigateway view-usage-plan
ncd_aws_apigateway_view-usage-plan() {
  local region="" usage_plan_id=""
  local -a list_args=()

  while (("$#")); do
    case "${1}" in
    --region)
      region="${2}"
      shift 2
      ;;
    --usage-plan-id)
      usage_plan_id="${2}"
      shift 2
      ;;
    --refresh)
      list_args+=("--refresh")
      shift
      ;;
    *)
      shift
      ;;
    esac
  done

  __ncd_aws_apigateway_resolve_region "${region}"

  if [[ -z "${usage_plan_id}" ]]; then
    local selected
    selected="$(ncd aws:apigateway:list-usage-plans "${list_args[@]}" | fzf --header="Usage Plan")"
    assert_val "${selected}" "no usage plan selected"
    usage_plan_id="$(echo "${selected}" | awk '{ print $1 }')"
  else
    ncd aws:apigateway:list-usage-plans "${list_args[@]}" >/dev/null
  fi

  assert_val "${usage_plan_id}" "missing usage-plan-id"

  local -r cache_file="${XDG_CACHE_HOME}/ncd/aws_apigateway_list-usage-plans_${AWS_REGION}.json"
  cat "${cache_file}" | jq --arg id "${usage_plan_id}" '.items[] | select(.id == $id)'
}

# ncd aws apigateway change-usage-plan
ncd_aws_apigateway_change-usage-plan() {
  local region="" key_id="" api_key="" usage_plan_id=""

  while (("$#")); do
    case "${1}" in
    --region)
      region="${2}"
      shift 2
      ;;
    --key-id)
      key_id="${2}"
      shift 2
      ;;
    --api-key)
      api_key="${2}"
      shift 2
      ;;
    --usage-plan-id)
      usage_plan_id="${2}"
      shift 2
      ;;
    *)
      shift
      ;;
    esac
  done

  __ncd_aws_apigateway_resolve_region "${region}"

  key_id="$(__ncd_aws_apigateway_resolve_key_id "${key_id}" "${api_key}")"
  assert_val "${key_id}" "missing key-id"

  local current_plans
  current_plans="$(aws apigateway get-usage-plans --key-id "${key_id}" --output json)"
  local old_plan_id old_plan_name
  old_plan_id="$(echo "${current_plans}" | jq -r '.items[0].id // ""')"
  old_plan_name="$(echo "${current_plans}" | jq -r '.items[0].name // ""')"

  if [[ -z "${usage_plan_id}" ]]; then
    local selected
    selected="$(ncd aws:apigateway:list-usage-plans | fzf --header="Select Usage Plan")"
    assert_val "${selected}" "no usage plan selected"
    usage_plan_id="$(echo "${selected}" | awk '{ print $1 }')"
  fi
  assert_val "${usage_plan_id}" "missing usage-plan-id"

  if [[ "${old_plan_id}" = "${usage_plan_id}" ]]; then
    echo_err "Key already in usage plan ${old_plan_name} (${old_plan_id})"
    exit 0
  fi

  local new_plan_name
  new_plan_name="$(ncd aws:apigateway:list-usage-plans | grep "^${usage_plan_id} " | cut -d' ' -f2-)"

  if [[ -n "${old_plan_id}" ]]; then
    local old_plan_data new_plan_data
    old_plan_data="$(ncd aws:apigateway:view-usage-plan --usage-plan-id "${old_plan_id}")"
    new_plan_data="$(ncd aws:apigateway:view-usage-plan --usage-plan-id "${usage_plan_id}")"

    local old_file new_file
    old_file="$(mktemp)"
    new_file="$(mktemp)"

    echo "${old_plan_data}" |
      jq -r '
        [
          "Name:             " + .name,
          "ID:               " + .id,
          "Description:      " + (.description // "-"),
          "Quota Limit:      " + (.quota.limit // "-" | tostring),
          "Quota Period:     " + (.quota.period // "-"),
          "Throttle Burst:   " + (.throttle.burstLimit // "-" | tostring),
          "Throttle Rate:    " + (.throttle.rateLimit // "-" | tostring)
        ] | .[]' >"${old_file}"

    echo "${new_plan_data}" |
      jq -r '
        [
          "Name:             " + .name,
          "ID:               " + .id,
          "Description:      " + (.description // "-"),
          "Quota Limit:      " + (.quota.limit // "-" | tostring),
          "Quota Period:     " + (.quota.period // "-"),
          "Throttle Burst:   " + (.throttle.burstLimit // "-" | tostring),
          "Throttle Rate:    " + (.throttle.rateLimit // "-" | tostring)
        ] | .[]' >"${new_file}"

    echo_err ""
    git diff --no-index --color-words --no-prefix \
      --src-prefix="Current:  " \
      --dst-prefix="New:  " \
      "${old_file}" "${new_file}" >&2 || true
    echo_err ""

    rm -f "${old_file}" "${new_file}"
  else
    echo_err ""
    echo_err "New Usage Plan:"
    ncd aws:apigateway:view-usage-plan --usage-plan-id "${usage_plan_id}" |
      jq -r '
        [
          "  Name:             " + .name,
          "  ID:               " + .id,
          "  Description:      " + (.description // "-"),
          "  Quota Limit:      " + (.quota.limit // "-" | tostring),
          "  Quota Period:     " + (.quota.period // "-"),
          "  Throttle Burst:   " + (.throttle.burstLimit // "-" | tostring),
          "  Throttle Rate:    " + (.throttle.rateLimit // "-" | tostring)
        ] | .[]' >&2
    echo_err ""
  fi

  read -p "Change usage plan from '${old_plan_name}' to '${new_plan_name}'? [yN] " -n 1 -r
  echo
  case ${REPLY} in
  y | Y) ;;
  *) exit 1 ;;
  esac

  if [[ -n "${old_plan_id}" ]]; then
    aws apigateway delete-usage-plan-key \
      --usage-plan-id "${old_plan_id}" \
      --key-id "${key_id}"
    echo_err "Removed key from usage plan ${old_plan_name}"
  fi

  aws apigateway create-usage-plan-key \
    --usage-plan-id "${usage_plan_id}" \
    --key-id "${key_id}" \
    --key-type "API_KEY"
  echo_err "Added key to usage plan ${new_plan_name}"
}

# ncd aws apigateway get-usage
ncd_aws_apigateway_get-usage() {
  local region="" usage_plan_id="" key_id="" start_date="" end_date="" api_key=""
  local refresh="false"
  local plot="false"

  while (("$#")); do
    case "${1}" in
    --region)
      region="${2}"
      shift 2
      ;;
    --usage-plan-id)
      usage_plan_id="${2}"
      shift 2
      ;;
    --key-id)
      key_id="${2}"
      shift 2
      ;;
    --api-key)
      api_key="${2}"
      shift 2
      ;;
    --start-date)
      start_date="${2}"
      shift 2
      ;;
    --end-date)
      end_date="${2}"
      shift 2
      ;;
    --refresh)
      refresh="true"
      shift
      ;;
    --plot)
      plot="true"
      shift
      ;;
    *)
      shift
      ;;
    esac
  done

  __ncd_aws_apigateway_resolve_region "${region}"

  key_id="$(__ncd_aws_apigateway_resolve_key_id "${key_id}" "${api_key}")"
  assert_val "${key_id}" "missing key-id"

  if [[ -z "${usage_plan_id}" ]]; then
    usage_plan_id="$(ncd aws:apigateway:get-usage-plan --key-id "${key_id}")"
  fi
  assert_val "${usage_plan_id}" "missing usage-plan-id"

  start_date="${start_date:-$(date +%Y-%m-01)}"
  end_date="${end_date:-$(date +%Y-%m-%d)}"

  local -r cache_file="${XDG_CACHE_HOME}/ncd/aws_apigateway_get-usage_${usage_plan_id}_${key_id}_${start_date}_${end_date}.json"

  local result=""
  if [[ "${refresh}" = "true" ]]; then
    rm -f "${cache_file}"
  elif [[ -f "${cache_file}" && -n "$(find "${cache_file}" -mmin -30)" ]]; then
    result="$(cat "${cache_file}")"
  fi

  if [[ -z "${result}" ]]; then
    result="$(aws apigateway get-usage \
      --usage-plan-id "${usage_plan_id}" \
      --key-id "${key_id}" \
      --start-date "${start_date}" \
      --end-date "${end_date}")"

    mkdir -p "$(dirname "${cache_file}")"
    echo "${result}" >"${cache_file}"
  fi

  if [[ "${plot}" = "true" ]]; then
    local max_used
    max_used="$(echo "${result}" | jq -r '.items | to_entries[0].value | map(.[0]) | max')"

    echo "${result}" |
      jq -r '
        (.startDate | split("-")[2] | tonumber) as $startDay |
        (["Day", "Used", "Remaining"]),
        (.items | to_entries[0].value | to_entries[] |
          [($startDay + .key), .value[0], .value[1]]
        ) | @tsv
      ' |
      uplot lineplots \
        -H --fmt xyy \
        -t "API Plan Usage" \
        -w 80 \
        -h 20 \
        --grid \
        --ylim "0,${max_used}"
  else
    echo "${result}"
  fi
}

# ncd aws:apigateway:update-usage
ncd_aws_apigateway_update-usage() {
  local region="" usage_plan_id="" key_id="" api_key=""
  local refresh="false"
  local -a args=()

  while (("$#")); do
    case "${1}" in
    --region)
      region="${2}"
      shift 2
      ;;
    --usage-plan-id)
      usage_plan_id="${2}"
      shift 2
      ;;
    --key-id)
      key_id="${2}"
      shift 2
      ;;
    --api-key)
      api_key="${2}"
      shift 2
      ;;
    --refresh)
      refresh="true"
      shift
      ;;
    *)
      args+=("${1}")
      shift
      ;;
    esac
  done

  __ncd_aws_apigateway_resolve_region "${region}"

  key_id="$(__ncd_aws_apigateway_resolve_key_id "${key_id}" "${api_key}")"
  assert_val "${key_id}" "missing key-id"

  if [[ -z "${usage_plan_id}" ]]; then
    usage_plan_id="$(ncd aws:apigateway:get-usage-plan --key-id "${key_id}")"
  fi
  assert_val "${usage_plan_id}" "missing usage-plan-id"

  local -a get_usage_args=("--usage-plan-id" "${usage_plan_id}" "--key-id" "${key_id}")
  [[ "${refresh}" = "true" ]] && get_usage_args+=("--refresh")

  local current_usage
  current_usage="$(ncd aws:apigateway:get-usage "${get_usage_args[@]}")"
  local current_value
  current_value="$(echo "${current_usage}" | jq -r ".items | to_entries[] | .value | last | .[1]")"

  echo_err "Current Remaining: ${current_value}"

  local value="${args[1]:-}"
  if [[ -z "${value}" ]]; then
    read -e -p "Replace Remaining: " value
  fi
  assert_val "${value}" "missing value"

  read -p "Update to ${value}? [yN] " -n 1 -r
  case ${REPLY} in
  y | Y) ;;
  *) exit 1 ;;
  esac

  # https://docs.aws.amazon.com/apigateway/latest/api/patch-operations.html#UpdateUsage-Patch
  aws apigateway update-usage \
    --usage-plan-id "${usage_plan_id}" \
    --key-id "${key_id}" \
    --patch-operations "op=replace,path=/remaining,value=${value}"
}

# ncd aws:codeartifact-auth-token
ncd_aws_codeartifact-auth-token() {
  if [[ ! -e "${XDG_CACHE_HOME}/newscred_aws_codeartifact_off" &&
    ! (-f "${AWS_CODEARTIFACT_TOKEN_CACHE_FILE}" &&
    -n "$(find "${AWS_CODEARTIFACT_TOKEN_CACHE_FILE}" -mmin -$((10 * 60)))") ]]; then
    if aws sts get-caller-identity --query "Account" >/dev/null 2>&1; then
      AWS_CODEARTIFACT_AUTH_TOKEN="$(aws codeartifact get-authorization-token \
        --duration-seconds "$((10 * 60 * 60))" \
        --domain "$(ncd config aws.domain)" \
        --domain-owner "$(ncd config aws.domain_owner)" \
        --query authorizationToken \
        --output text)"

      if test -n "${AWS_CODEARTIFACT_AUTH_TOKEN}"; then
        echo -n "${AWS_CODEARTIFACT_AUTH_TOKEN}" >"${AWS_CODEARTIFACT_TOKEN_CACHE_FILE}"
      fi
    fi
  fi

  cat "${AWS_CODEARTIFACT_TOKEN_CACHE_FILE}"
}

