# ncd dc
ncd_dc() {
  __pyenv_init
  __pyenv_virtualenv_activate localdev

  local cmd="${1:-}"
  shift || true

  if test -z "${cmd}"; then
    cmd="$(__ncd_dc_list_commands | fzf --header=Command)"
  fi

  local args=()
  local containers=()

  case "${cmd}" in
  build | up | logs | restart | shell)
    while (("$#")); do
      case "${1}" in
      *)
        if __ncd_is_container "${1}"; then
          containers+=("${1}")
        else
          args+=("${1}")
        fi
        shift
        ;;
      esac
    done
    if test "${#containers[@]}" -eq 0; then
      containers+=("$(__ncd_current_repo)")
    fi
    ;;
  *)
    while (("$#")); do
      args+=("${1}")
      shift
    done
    ;;
  esac

  case "${cmd}" in
  logs)
    if test "${#args[@]}" -eq 0; then
      args+=("-f" "--tail" "1000")
    fi
    if test "${#containers[@]}" -eq 1; then
      args+=("--no-log-prefix")
    fi
    ;;
  esac

  case "${cmd}" in
  build | up | logs | restart | shell)
    exec nc-docker ${cmd} "${args[@]}" "${containers[@]}"
    ;;
  *)
    exec nc-docker ${cmd} "${args[@]}"
    ;;
  esac
}

