#!/usr/bin/env bash

set -euo pipefail

declare GITHUB_USERNAME="MunifTanjim"

command_exists() {
  type "${1}" >/dev/null 2>&1
}

assert_command() {
  if ! type "${1}" >/dev/null 2>&1; then
    echo "${2:-"command not found: ${1}"}"
    exit 1
  fi
}

assert_dir() {
  if ! [[ -d "${1}" ]]; then
    echo "${2}"
    exit 1
  fi
}

assert_val() {
  if [[ -z "${1}" ]]; then
    echo "${2}"
    exit 1
  fi
}

assert_func() {
  if ! declare -F "${1}" >/dev/null; then
    echo "${2}"
    exit 1
  fi
}

echo_err() {
  >&2 echo "$@"
}

ncd_config() {
  assert_command rq

  local blob="$(cat ~/.newscred.yaml | rq --input-yaml | jq -r '.ncd')"
  echo "${blob}" | jq -r ".${1:-""}"
}

ncd_workspace() {
  assert_command rq

  local dir="$(cat ~/.newscred.yaml | rq --input-yaml | jq -r '.workspace')"
  dir="${dir/#\~/${HOME}}"
  echo "${dir}"
}

__pyenv_init() {
  if [[ "${PYENV_VIRTUAL_INIT:-}" != "1" ]]; then
    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)"
  fi
}

__pyenv_list_versions() {
  pyenv versions --bare --skip-envs --skip-aliases
}

__pyenv_virtualenv_exists() {
  local -r virtualenvs="$(pyenv virtualenvs --bare)"
  echo "${virtualenvs}" | grep -q "${1}"
}

__pyenv_is_version_installed() {
  local -r versions="$(__pyenv_list_versions)"
  echo "${versions}" | grep -q "${1}"
}

__pyenv_virtualenv_current() {
  local name="$(basename "${PYENV_VIRTUAL_ENV:-}")"
  if test -n "${name}"; then
    echo "${name}"
  else
    pyenv virtualenvs | grep "^* " | awk '{ print $2 }'
  fi
}

__pyenv_virtualenv_activate() {
  local name="${1}"
  if [[ "$(__pyenv_virtualenv_current)" = "${name}" ]]; then
    return
  fi
  pyenv activate "${name}"
}

__ncd_is_inside_workspace_repo() {
  [[ "${PWD}" = "$(ncd workspace)"/* ]]
}

__ncd_is_container() {
  ncd_list_container | grep -q "${1}"
}

__ncd_assert_inside_workspace_repo() {
  if ! __ncd_is_inside_workspace_repo; then
    echo "not inside workspace repo"
    exit 1
  fi
}

__ncd_current_repo() {
  if ! __ncd_is_inside_workspace_repo; then
    echo ""
  fi

  echo "$(basename "$(git rev-parse --show-toplevel)")"
}

__ncd_py_venv_name() {
  local -r curr_repo="$(__ncd_current_repo)"
  local venv_name="nc-${curr_repo}"
  if [[ "${PWD}" != "$(ncd workspace)/${curr_repo}" ]]; then
    venv_name="${venv_name}${PWD:(($(ncd workspace | wc -c) + ${#curr_repo}))}"
    venv_name="${venv_name//\//-}"
  fi
  echo "${venv_name}"
}

__ncd_assert_py_repo_venv() {
  local -r venv_name="$(__ncd_py_venv_name)"
  if [[ "$(__pyenv_virtualenv_current)" != "${venv_name}" ]]; then
    echo "virtualenv not active: ${venv_name}"
    exit 1
  fi
}

__ncd_cmd() {
  local -r cmd="${1}"
  shift

  local -r subcmd="${1:-}"
  assert_val "${subcmd}" "missing param"
  shift

  local -r func="ncd_${cmd// /_}_${subcmd//:/_}"
  assert_func "${func}" "invalid param: ${subcmd}"

  $func "$@"
}

# ncd completion
ncd_completion() {
  local dir="$(realpath "${BASH_SOURCE[0]}")"
  dir="${dir%/*}"
  local -r completion_file="${dir}/completions/_ncd"
  if test -f "${completion_file}"; then
    cat "${completion_file}"
  else
    curl -fsSL https://raw.githubusercontent.com/MunifTanjim/scripts.sh/main/completions/_ncd
  fi
}

AWS_CODEARTIFACT_TOKEN_CACHE_FILE="${HOME}/.nc_codeartifact_token"

__ncd_aws_apigateway_resolve_region() {
  local region="${1:-"${AWS_REGION:-"${AWS_DEFAULT_REGION:-"us-east-1"}"}"}"
  export AWS_REGION="${region}"
}

__ncd_aws_apigateway_resolve_key_id() {
  local key_id="${1}" api_key="${2}"
  if [[ -z "${key_id}" ]]; then
    if [[ -n "${api_key}" ]]; then
      key_id="$(ncd aws:apigateway:get-api-key --api-key "${api_key}")"
    else
      key_id="$(ncd aws:apigateway:get-api-key)"
    fi
  fi
  echo -n "${key_id}"
}

# ncd aws apigateway get-api-key
ncd_aws_apigateway_get-api-key() {
  local region="" api_key=""
  local refresh="false"

  while (("$#")); do
    case "${1}" in
    --region)
      region="${2}"
      shift 2
      ;;
    --api-key)
      api_key="${2}"
      shift 2
      ;;
    --refresh)
      refresh="true"
      shift
      ;;
    *)
      shift
      ;;
    esac
  done

  __ncd_aws_apigateway_resolve_region "${region}"

  if [[ -z "${api_key}" ]]; then
    read -e -p "API Key: " api_key
  fi
  assert_val "${api_key}" "missing param: --api-key"

  local -r cache_file="${XDG_CACHE_HOME}/ncd/aws_apigateway_api-keys_${AWS_REGION}.json"

  if [[ "${refresh}" = "true" ]]; then
    rm -f "${cache_file}"
  fi

  local result=""
  if [[ "${refresh}" = "true" ]]; then
    rm -f "${cache_file}"
  elif [[ -f "${cache_file}" && -n "$(find "${cache_file}" -mmin -90)" ]]; then
    result="$(cat "${cache_file}")"
  fi

  if [[ -z "${result}" ]]; then
    result="$(aws apigateway get-api-keys \
      --include-values \
      --output json)"

    mkdir -p "$(dirname "${cache_file}")"
    echo "${result}" >"${cache_file}"
  fi

  local key_id
  key_id="$(echo "${result}" | jq -r --arg api_key "${api_key}" '.items[] | select(.value == $api_key) | .id')"
  assert_val "${key_id}" "api key not found: ${api_key}"

  echo -n "${key_id}"
}

# ncd aws apigateway get-usage-plan
ncd_aws_apigateway_get-usage-plan() {
  local region="" key_id="" api_key=""
  local refresh="false"

  while (("$#")); do
    case "${1}" in
    --region)
      region="${2}"
      shift 2
      ;;
    --key-id)
      key_id="${2}"
      shift 2
      ;;
    --api-key)
      api_key="${2}"
      shift 2
      ;;
    --refresh)
      refresh="true"
      shift
      ;;
    *)
      shift
      ;;
    esac
  done

  __ncd_aws_apigateway_resolve_region "${region}"

  key_id="$(__ncd_aws_apigateway_resolve_key_id "${key_id}" "${api_key}")"
  assert_val "${key_id}" "missing key-id"

  local -r cache_file="${XDG_CACHE_HOME}/ncd/aws_apigateway_usage-plans_${AWS_REGION}_${key_id}.json"

  if [[ "${refresh}" = "true" ]]; then
    rm -f "${cache_file}"
  fi

  local result=""
  if [[ "${refresh}" = "true" ]]; then
    rm -f "${cache_file}"
  elif [[ -f "${cache_file}" && -n "$(find "${cache_file}" -mmin -30)" ]]; then
    result="$(cat "${cache_file}")"
  fi

  if [[ -z "${result}" ]]; then
    result="$(aws apigateway get-usage-plans \
      --key-id "${key_id}" \
      --output json)"

    mkdir -p "$(dirname "${cache_file}")"
    echo "${result}" >"${cache_file}"
  fi

  local selected
  selected="$(echo "${result}" | jq -r '.items[] | .id + " " + .name' | fzf --header="Usage Plan" --select-1)"
  assert_val "${selected}" "no usage plan selected"

  local usage_plan_id
  usage_plan_id="$(echo "${selected}" | awk '{ print $1 }')"

  echo -n "${usage_plan_id}"
}

